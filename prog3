import PromptSync from 'prompt-sync';
const prompt = PromptSync();

const name = prompt("Enter the name: ");
const grade = parseInt(prompt("Enter the grade: "));
const subjects = prompt("Enter the subjects separated by commas: ")
                .split(',')
                .map(subject => subject.trim());

const student = {
    name: name,
    grade: grade,
    subjects: subjects,
    
    displayInfo: function() {
        console.log("Student details:");
        console.log(`Name is ${this.name}`);
        console.log(`Grade is ${this.grade}`);
        console.log(`Subjects are ${this.subjects.join(', ')}`);
    }
};

student.passed = student.grade >= 40;
student.displayInfo();

console.log("Complete student details:");
for (let key in student) {
    if (typeof student[key] !== 'function') {
        console.log(`${key}: ${typeof student[key] === 'object' ? JSON.stringify(student[key]) : student[key]}`);
    }
}
